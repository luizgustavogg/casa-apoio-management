{
  "info": {
    "name": "Casa de Apoio - Management API",
    "_postman_id": "casa-apoio-management-v1",
    "description": "Complete API collection for Casa de Apoio Management System.\n\nSetup:\n1. Create an environment with variable `base_url` = http://127.0.0.1:8000\n2. Run 'Login' to obtain a token\n3. The token is saved automatically to the `token` environment variable",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@casaapoio.com\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/",
              "host": ["{{base_url}}"],
              "path": ["users", ""]
            },
            "description": "Creates a new user. Password rules: min 8 chars, 1 uppercase, 1 digit, 1 special char."
          }
        },
        {
          "name": "Login (get token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.environment.set('token', json.token);",
                  "    console.log('Token saved:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login/",
              "host": ["{{base_url}}"],
              "path": ["login", ""]
            },
            "description": "Authenticates the user and returns a token. The test script automatically saves the token to `token` collection variable."
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/1/",
              "host": ["{{base_url}}"],
              "path": ["users", "1", ""]
            },
            "description": "Retrieves a user by ID."
          }
        }
      ]
    },
    {
      "name": "House Configuration",
      "description": "Manage the support house capacity and monitor occupancy in real time.",
      "item": [
        {
          "name": "Get Occupancy Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/house-configuration/occupancy_status/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "house-configuration", "occupancy_status", ""]
            },
            "description": "Returns current occupancy status: max capacity, current occupancy, available vacancies, and whether the house is at full capacity."
          }
        },
        {
          "name": "List Configuration",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/house-configuration/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "house-configuration", ""]
            }
          }
        },
        {
          "name": "Update Max Capacity",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"max_capacity\": 25\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/house-configuration/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "house-configuration", "1", ""]
            },
            "description": "Updates the maximum capacity of the support house. Uses singleton pk=1."
          }
        },
        {
          "name": "Partial Update Max Capacity",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"max_capacity\": 30\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/house-configuration/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "house-configuration", "1", ""]
            }
          }
        }
      ]
    },
