          "name": "Create Check-in (patient with companion)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"person\": 1,\n  \"reason\": \"patient\",\n  \"companion\": 2,\n  \"chemotherapy\": true,\n  \"radiotherapy\": false,\n  \"surgery\": false,\n  \"exams\": false,\n  \"appointment\": true,\n  \"other\": false,\n  \"ca_number\": \"CA-001\",\n  \"social_vacancy\": true,\n  \"observation\": \"Paciente em tratamento quimioterápico\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/checkins/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "checkins", ""]
            },
            "description": "Patient check-in — companion field is required when reason is 'patient'."
          }
        },
        {
          "name": "Get Check-in",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/checkins/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "checkins", "1", ""]
            }
          }
        },
        {
          "name": "Deactivate Check-in (PATCH active=false)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
