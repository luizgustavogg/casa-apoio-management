        {
          "name": "Create Check-in (professional / voluntary / visitor)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"person\": 1,\n  \"reason\": \"professional\",\n  \"observation\": \"Médico voluntário\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/checkins/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "checkins", ""]
            },
            "description": "reason options: patient | companion | professional | voluntary | visitor | other\n\nIf house is at full capacity, returns HTTP 400 with: { \"detail\": \"Casa de apoio em capacidade máxima. Não há vagas disponíveis no momento.\" }"
          }
        },
